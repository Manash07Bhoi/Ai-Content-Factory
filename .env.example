# Environment Configuration

NODE_ENV=development
PORT=3000

# PostgreSQL
DATABASE_URL=postgresql://aicf_user:aicf_password@localhost:5432/aicf_db

# MongoDB
MONGODB_URI=mongodb://aicf_mongo_user:aicf_mongo_password@localhost:27017/?authSource=admin

# Redis (Cache & BullMQ)
REDIS_URL=redis://localhost:6379

# Auth
JWT_ACCESS_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# APIs (To be filled)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
STABILITY_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# S3 Storage (To be filled)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_PRIVATE=
AWS_S3_BUCKET_PUBLIC=
AWS_REGION=us-east-1

# SMTP Email (To be filled)
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
FRONTEND_URL=http://localhost:5173

# Observability
LOG_LEVEL=debug
